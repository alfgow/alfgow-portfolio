---
import TerminalIcon from '../../atoms/terminal-icon/TerminalIcon.astro';
import Terminal from '../terminal/Terminal.astro';
import './skills-on-terminal.css';
---

<Terminal nombre="<alfgow/>">
	<div class="terminal__skills">
		<h2>Mis habilidades</h2>
		<div class="terminal__skills__container">
			<TerminalIcon
				src="/assets/Astro.svg"
				color="#7738ff"
				name="Astro"
			/>
			<TerminalIcon
				src="/assets/javascript.svg"
				color="yellow"
				name="JavaScript"
			/>
			<TerminalIcon
				src="/assets/react.svg"
				color="#00D1FF"
				name="React"
			/>
			<TerminalIcon src="/assets/mysql.svg" color="#F3CBC2" name="MySQL" />
			<TerminalIcon src="/assets/nodejs.svg" color="green" name="NodeJS" />
			<TerminalIcon
				src="/assets/tailwind.svg"
				color="#3F75FF"
				name="Tailwind"
			/>
			<TerminalIcon
				src="/assets/n8n.svg"
				color="#FF6D5A"
				name="n8n"
			/>
			<TerminalIcon
				src="/assets/openai.svg"
				color="#74AA9C"
				name="OpenAI"
			/>
			<TerminalIcon
				src="/assets/claude.svg"
				color="#D97757"
				name="Claude"
			/>
			<TerminalIcon
				src="/assets/openclaw.svg"
				color="#E05C3A"
				name="OpenClaw"
			/>
		</div>
	</div>
</Terminal>
