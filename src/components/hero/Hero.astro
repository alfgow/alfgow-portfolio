---
import Boton from '../atoms/Boton.astro';
import './hero.css';
---

<section class="hero">

	<div class="hero__container">
		<div class="text__content">
			<h1 class="hero__title color__gradiente">Alfgow</h1>
			<p class="hero__text">
				Hola! Soy Alfonso, un chavo Sr. muy dinamico que le gusta programar sitios web.
			</p>
			<Boton href="#about" texto="Quiero saber más"/>
		</div>
    <img
		class="hero__img"
		src="/img/alfgow.webp"
		alt="Alfgow"
		width="384"
    	height="384"
	/>
	</div>
</section>
