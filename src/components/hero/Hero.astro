---
import Boton from '../atoms/Boton.astro';
import './hero.css';
---

<section class="hero">

	<div class="hero__container">
		<div class="text__content">
			<h1 class="hero__title color__gradiente">Alfgow</h1>
            <div class="flex items-center justify-start gap-4 my-6">
  <img
    src="https://alfgow.s3.mx-central-1.amazonaws.com/aws-educate-introduction-to-cloud-101-removebg-preview.png"
    alt="Certificación AWS Educate"
    class="h-20 object-contain"
  />
  <img
    src="https://alfgow.s3.mx-central-1.amazonaws.com/aws-cloud-quest-cloud-practitioner-removebg-preview.png"
    alt="Certificación Cloud Practitioner"
    class="h-20 object-contain"
  />
</div>

			<p class="hero__text">
				Hola! Soy Alfonso, un chavo Sr. muy dinamico que le gusta programar sitios web.
			</p>
			<Boton href="#about" texto="Quiero saber más"/>
		</div>
    <img
		class="hero__img"
		src="/img/alfgow.webp"
		alt="Alfgow"
		width="384"
    	height="384"
	/>
	</div>
</section>
