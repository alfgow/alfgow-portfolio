---
import { type CollectionEntry, getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

export async function getStaticPaths() {
	const posts = await getCollection('blog');
	return posts.map((post) => ({
		params: { slug: post.slug },
		props: post,
	}));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content } = await post.render();
---

<BlogLayout {...post.data}>
	<Content />
</BlogLayout>

<style is:global>
	.blog-content {
		color: white;
	}

	.blog-content p {
		font-size: 1.8rem;
		line-height: 1.9;
		color: rgba(255, 255, 255, 0.86);
		margin: 0 0 1.8rem;
	}

	.blog-content h2,
	.blog-content h3,
	.blog-content h4,
	.blog-content h5,
	.blog-content h6 {
		color: white;
		font-weight: 800;
		line-height: 1.15;
		margin: 3rem 0 1.2rem;
	}

	.blog-content h2 {
		font-size: clamp(2.6rem, 4vw, 3.6rem);
	}

	.blog-content h3 {
		font-size: clamp(2.1rem, 3vw, 2.8rem);
	}

	.blog-content p:has(> img) {
		display: flex;
		justify-content: center;
		margin: 2.4rem 0;
	}

	.blog-content p > img {
		width: min(100%, 72rem);
		border-radius: 2.4rem;
		border: 1px solid rgba(255, 255, 255, 0.12);
		box-shadow: 0 1.6rem 4rem rgba(0, 0, 0, 0.25);
	}

	.blog-content blockquote {
		margin: 2.6rem 0;
		padding: 1.8rem 2rem;
		border-left: 4px solid var(--secondary-60);
		border-radius: 1.6rem;
		background: rgba(255, 255, 255, 0.05);
	}

	.blog-content blockquote p {
		margin: 0;
		font-size: 1.7rem;
		color: var(--secondary-95);
	}

	.blog-content ul,
	.blog-content ol {
		margin: 1.2rem 0 2rem 2.2rem;
		padding: 0;
	}

	.blog-content li {
		margin: 0.7rem 0;
		font-size: 1.7rem;
		line-height: 1.8;
		color: rgba(255, 255, 255, 0.84);
	}

	.blog-content strong {
		color: white;
	}

	.blog-content table {
		width: 100%;
		margin: 2.4rem 0;
		border-collapse: collapse;
		overflow: hidden;
		border-radius: 1.8rem;
		background: rgba(255, 255, 255, 0.04);
		border: 1px solid rgba(255, 255, 255, 0.08);
	}

	.blog-content th,
	.blog-content td {
		padding: 1.3rem 1.5rem;
		text-align: left;
		font-size: 1.5rem;
		border-bottom: 1px solid rgba(255, 255, 255, 0.08);
		color: rgba(255, 255, 255, 0.88);
	}

	.blog-content th {
		background: rgba(255, 255, 255, 0.06);
		font-weight: 700;
		color: white;
	}

	.blog-content pre {
		font-size: 1.5rem;
		padding: 1.4rem 1.6rem;
		margin: 2.4rem 0;
		border-radius: 1.6rem;
		overflow-x: auto;
		background: rgba(255, 255, 255, 0.05);
		border: 1px solid rgba(255, 255, 255, 0.08);
	}

	.blog-content hr {
		border: 0;
		height: 1px;
		margin: 3rem 0;
		background: linear-gradient(90deg, transparent, rgba(255, 255, 255, 0.22), transparent);
	}

	@media screen and (max-width: 768px) {
		.blog-content p,
		.blog-content li {
			font-size: 1.6rem;
		}

		.blog-content table,
		.blog-content thead,
		.blog-content tbody,
		.blog-content th,
		.blog-content td,
		.blog-content tr {
			display: block;
		}

		.blog-content tr {
			margin-bottom: 1rem;
		}

		.blog-content th,
		.blog-content td {
			padding: 1rem 1.2rem;
		}
	}
</style>
